{
  "name": "@stategraph/react",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./devtools": {
      "import": {
        "types": "./dist/devtools.d.ts",
        "default": "./dist/devtools.js"
      },
      "require": {
        "types": "./dist/devtools.d.cts",
        "default": "./dist/devtools.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stategraph/stategraph-ts.git"
  },
  "scripts": {
    "build": "tsup && cp dist/index.d.ts dist/index.d.cts && cp dist/devtools.d.ts dist/devtools.d.cts",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "lint": "eslint src tsup.config.ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@stategraph/core": "workspace:*",
    "@stategraph/inspect": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@stategraph/testing": "workspace:*",
    "@types/react": "*",
    "@types/react-dom": "*",
    "happy-dom": "*",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
